NEXT_PUBLIC_NETWORK=testnet
NEXT_PUBLIC_COVERED_CALL_CONTRACT=
NEXT_PUBLIC_PUT_VAULT_CONTRACT=
NEXT_PUBLIC_USDC_CONTRACT=
NEXT_PUBLIC_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org
NEXT_PUBLIC_XLM_PRICE_FALLBACK=0.10

# Lusty testnet USD
NEXT_PUBLIC_LUSD_CODE=LUSD
NEXT_PUBLIC_LUSD_ISSUER=
NEXT_PUBLIC_LUSD_DISTRIBUTOR=

# Server-side secrets (never commit these)
LUSD_DISTRIBUTOR_SECRET=
LUSD_ISSUER_SECRET=
VAULT_CAP_XLM=1000000
VAULT_XLM_BASELINE=30000

# Database
DATABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Gemini AI
GEMINI_API_KEY=

# Fee wallet — protocol revenue goes here (Stellar public key)
FEE_WALLET=

# SSL: set to false only for Supabase connection pooler in dev
DB_SSL_REJECT_UNAUTHORIZED=false

# CORS
CORS_ORIGIN=http://localhost:3000

# Risk monitoring alerts (P1-7) — both channels optional, both best-effort.
# Slack incoming webhook:
MONITOR_SLACK_WEBHOOK_URL=
# Email via Resend (https://resend.com). Comma-separate multiple recipients:
RESEND_API_KEY=
MONITOR_ALERT_EMAIL_TO=
MONITOR_ALERT_EMAIL_FROM=Lusty Monitor <alerts@lusty.finance>
# Label shown in every alert (e.g. testnet / mainnet):
MONITOR_ENV_LABEL=testnet
# Secret for the scheduled monitor endpoint (/api/cron/monitor). Vercel cron
# sends it as a Bearer token; unset = endpoint disabled (fail closed):
CRON_SECRET=
# Monitor thresholds:
MONITOR_CAP_WARN_PCT=90
MONITOR_LATENCY_BUDGET_MS=4000
MONITOR_VOL_SPIKE_MULT=2
